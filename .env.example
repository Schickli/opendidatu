# SQLite database path.
# Defaults to ./data/opendidatu.sqlite when unset.
DATABASE_PATH=./data/opendidatu.sqlite

# Map asset directory and file overrides.
# By default the app uses ./map/demo.mbtiles, ./map/tiles.json and ./map/style.json.
MAP_DATA_DIR=./map
MAP_MBTILES_PATH=./map/demo.mbtiles
MAP_TILE_METADATA_PATH=./map/tiles.json
MAP_STYLE_PATH=./map/style.json

# Automatically download missing map assets on startup.
MAP_AUTO_DOWNLOAD=true

# Seeds the database with sample data on first startup.
# true  -> always seed when the database is empty
# false -> never seed
# unset -> seed only outside production
SEED_SAMPLE_DATA=true