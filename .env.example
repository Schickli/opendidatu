# SQLite database path.
# Defaults to ./data/opendidatu.sqlite when unset.
DATABASE_PATH=./data/opendidatu.sqlite

# Seeds the database with sample data on first startup.
# true  -> always seed when the database is empty
# false -> never seed
# unset -> seed only outside production
SEED_SAMPLE_DATA=true

# Local MBTiles file for offline vector tile serving.
# Leave empty to keep using the configured style source as-is.
MAP_MBTILES_PATH=

# Optional metadata JSON matching the MBTiles dataset.
MAP_METADATA_JSON_PATH=

# Optional local style template file.
# If unset, the app falls back to MAP_STYLE_URL.
MAP_STYLE_JSON_PATH=

# Fallback remote style URL used when MAP_STYLE_JSON_PATH is not set.
MAP_STYLE_URL=https://vectortiles.geo.admin.ch/styles/ch.swisstopo.lightbasemap.vt/style.json

# Optional glyphs URL or local route for fully offline label rendering.
MAP_GLYPHS_URL=

# Optional sprite URL or local route for fully offline icon rendering.
MAP_SPRITE_URL=